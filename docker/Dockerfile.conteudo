# ===== BUILD =====
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Copia apenas os csproj primeiro (cache inteligente)
COPY src/services/TelesEducacao.Conteudo.API/*.csproj ./services/TelesEducacao.Conteudo.API/
COPY src/services/TelesEducacao.Conteudo.Application/*.csproj ./services/TelesEducacao.Conteudo.Application/
COPY src/services/TelesEducacao.Conteudo.Domain/*.csproj ./services/TelesEducacao.Conteudo.Domain/
COPY src/services/TelesEducacao.Conteudo.Data/*.csproj ./services/TelesEducacao.Conteudo.Data/
COPY src/building-blocks/TelesEducacao.Core/*.csproj ./building-blocks/TelesEducacao.Core/
COPY src/building-blocks/TelesEducacao.MessageBus/*.csproj ./building-blocks/TelesEducacao.MessageBus/
COPY src/building-blocks/TelesEducacao.WebAPI.Core/*.csproj ./building-blocks/TelesEducacao.WebAPI.Core/

# restore só do projeto (não da solution)
RUN dotnet restore ./services/TelesEducacao.Conteudo.API/TelesEducacao.Conteudo.API.csproj

# agora copia o resto
COPY src ./

WORKDIR /src/services/TelesEducacao.Conteudo.API
RUN dotnet publish -c Release -o /app/publish

# ===== RUNTIME =====
FROM mcr.microsoft.com/dotnet/aspnet:9.0
WORKDIR /app
COPY --from=build /app/publish .

EXPOSE 5301
ENTRYPOINT ["dotnet", "TelesEducacao.Conteudo.API.dll"]
